{
  "name": "gorules-editor",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w @gorules-editor/backend\" \"npm run dev -w @gorules-editor/frontend\"",
    "dev:backend": "npm run dev -w @gorules-editor/backend",
    "dev:frontend": "npm run dev -w @gorules-editor/frontend",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
